# Mesmo PostgreSQL do CNPJ ETL. O serviço escreve somente no schema outreach.
DATABASE_URL=postgresql://cnpj:cnpj@localhost:5432/cnpj

# Brevo SMTP. Gere uma NOVA chave SMTP e nunca versione a senha.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=COLOQUE_SEU_LOGIN_SMTP
SMTP_PASSWORD=COLOQUE_SUA_NOVA_CHAVE_SMTP
SMTP_STARTTLS=true
SMTP_TIMEOUT_SECONDS=30

# Remetente precisa estar verificado na Brevo.
OUTREACH_FROM_EMAIL=contato@seudominio.com.br
OUTREACH_FROM_NAME=Tironi Tech
OUTREACH_REPLY_TO=contato@seudominio.com.br

# URL pública usada no link de descadastro.
PUBLIC_BASE_URL=http://localhost:8000
UNSUBSCRIBE_SECRET=gere-uma-chave-aleatoria-longa
API_KEY=gere-uma-chave-para-proteger-a-api

# Proteções padrão. Mantenha aprovação manual no início.
REQUIRE_MANUAL_APPROVAL=true
DAILY_EMAIL_LIMIT=30
HOURLY_EMAIL_LIMIT=8
MAX_PER_DOMAIN_PER_DAY=2
MAX_FOLLOW_UPS=1
FOLLOW_UP_DELAY_DAYS=7
SEND_INTERVAL_SECONDS=30
SEND_START_HOUR=9
SEND_END_HOUR=17
APP_TIMEZONE=America/Sao_Paulo
WORKER_POLL_SECONDS=15
DRY_RUN=true

